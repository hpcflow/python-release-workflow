name: Build executables

on:
  workflow_dispatch:
    inputs:
      build_linux:
        description: "Build executables for linux?"
        required: true
        type: boolean
        default: true
      build_macos:
        description: "Build executables for macOS?"
        required: true
        type: boolean
        default: true
      build_windows:
        description: "Build executables for Windows?"
        required: true
        type: boolean
        default: true
      build_onedir:
        description: "Build one-dir?"
        required: true
        type: boolean
        default: true
      build_onefile:
        description: "Build one-file?"
        required: true
        type: boolean
        default: true
      logLevel:
        description: "PyInstaller log level"
        required: true
        default: "INFO"
      tmate_debugging:
        description: "Enable tmate debugging (https://github.com/marketplace/actions/debugging-with-tmate)"
        required: true
        default: false
        type: boolean
      unit_tests:
        description: "Run unit tests on the built executables."
        required: true
        default: true
        type: boolean
      unit_test_args:
        description: "CLI args to pass verbatim to pytest (unit tests)."
        required: false
        type: string
        default: ""
      integration_tests:
        description: "Run integration tests on the built executables."
        required: true
        default: true
        type: boolean
      integration_test_args:
        description: "CLI args to pass verbatim to pytest (integration tests)."
        required: false
        type: string
        default: ""
      config_data_dir:
        description: "URL to set the config item `data_dir` to before running the tests."
        type: string
        required: false
        default: ""
      config_program_dir:
        description: "URL to set the config item `program_dir` to before running the tests."
        type: string
        required: false
        default: ""

jobs:
  build-exes:
    uses: hpcflow/github-support/.github/workflows/build-exes-impl.yml@main
    with:
      {% raw %}build_linux: ${{ github.event.inputs.build_linux }}
      build_macos: ${{ github.event.inputs.build_macos }}
      build_windows: ${{ github.event.inputs.build_windows }}
      build_onedir: ${{ github.event.inputs.build_onedir }}
      build_onefile: ${{ github.event.inputs.build_onefile }}
      logLevel: ${{ github.event.inputs.logLevel }}
      tmate_debugging: ${{ github.event.inputs.tmate_debugging }}
      unit_tests: ${{ github.event.inputs.unit_tests }}
      unit_test_args: ${{ github.event.inputs.unit_test_args }}
      integration_tests: ${{ github.event.inputs.integration_tests }}
      integration_test_args: ${{ github.event.inputs.integration_test_args }}
      config_data_dir: ${{ github.event.inputs.config_data_dir }}
      config_program_dir: ${{ github.event.inputs.config_program_dir }}
      {% endraw %}executable_name: {{ executable_name }}
      pyinstaller_dir: {{ pyinstaller_dir }}
